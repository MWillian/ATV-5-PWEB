<%- include('../../partials/header', { titulo: 'Relatório: Motoristas Ativos' }) %>

<div class="deliver-list-container">
  <div class="page-header">
    <h1>Relatório: Motoristas Ativos com Entregas em Aberto</h1>
    <a href="/painel/relatorios" class="btn btn-link">&larr; Voltar ao Dashboard</a>
  </div>

  <section class="detail-section">
    <h2>Motoristas com Entregas</h2>

    <% if (motoristas && motoristas.length > 0) { %>
      <div class="data-grid" style="grid-template-columns: 1fr 1fr 1fr 1fr 1fr 1fr 1fr;">
        <div class="data-grid-header">
          <div class="data-grid-cell-header">ID</div>
          <div class="data-grid-cell-header">Nome</div>
          <div class="data-grid-cell-header">CPF</div>
          <div class="data-grid-cell-header">Placa do Veículo</div>
          <div class="data-grid-cell-header">Status</div>
          <div class="data-grid-cell-header">Entregas em Aberto</div>
          <div class="data-grid-cell-header">Ação</div>
        </div>
        
        <% motoristas.forEach(motorista => { %>
          <div class="data-grid-row">
            <div class="data-grid-cell"><strong><%= motorista.id %></strong></div>
            <div class="data-grid-cell"><%= motorista.nome %></div>
            <div class="data-grid-cell"><%= motorista.cpf %></div>
            <div class="data-grid-cell"><%= motorista.placaVeiculo %></div>
            <div class="data-grid-cell">
              <span class="badge badge-<%= motorista.status?.toLowerCase() || 'ativo' %>">
                <%= motorista.status || 'ATIVO' %>
              </span>
            </div>
            <div class="data-grid-cell"><strong><%= motorista.entregasEmAberto || 0 %></strong></div>
            <div class="data-grid-cell">
              <a href="/painel/motoristas/<%= motorista.id %>" class="btn btn-sm btn-outline">Ver Detalhes</a>
            </div>
          </div>
        <% }); %>
      </div>

      <div style="margin-top: 30px; padding: 20px; background-color: #f9f9f9; border-radius: 4px;">
        <p><strong>Total de Motoristas Ativos:</strong> <%= motoristas.length %></p>
        <p><strong>Total de Entregas em Aberto:</strong>
          <% 
            let totalEntregasAberto = 0;
            motoristas.forEach(m => {
              totalEntregasAberto += (m.entregasEmAberto || 0);
            });
          %>
          <strong><%= totalEntregasAberto %></strong>
        </p>
      </div>
    <% } else { %>
      <p style="color: var(--text-muted); padding: 40px; text-align: center;">Nenhum motorista ativo com entregas em aberto no momento.</p>
    <% } %>
  </section>
</div>