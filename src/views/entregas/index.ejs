<h1>Listagem de Entregas</h1>

<% if (typeof sucesso !== 'undefined' && sucesso) { %>
  <div class="sucesso">
    <p><%= sucesso %></p>
  </div>
<% } %>

<a href="/painel/entregas/novo">Nova Entrega</a>

<form method="GET" action="/painel/entregas">
  <label for="status">Filtrar por status:</label>
  <select id="status" name="status">
    <option value="" <%= !statusSelecionado ? 'selected' : '' %>>Todos</option>
    <option value="CRIADA" <%= statusSelecionado === 'CRIADA' ? 'selected' : '' %>>CRIADA</option>
    <option value="EM_TRANSITO" <%= statusSelecionado === 'EM_TRANSITO' ? 'selected' : '' %>>EM TRÂNSITO</option>
    <option value="ENTREGUE" <%= statusSelecionado === 'ENTREGUE' ? 'selected' : '' %>>ENTREGUE</option>
    <option value="CANCELADA" <%= statusSelecionado === 'CANCELADA' ? 'selected' : '' %>>CANCELADA</option>
  </select>
  <button type="submit">Filtrar</button>
  <a href="/painel/entregas">Limpar</a>
</form>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Descrição</th>
      <th>Origem</th>
      <th>Destino</th>
      <th>Status</th>
      <th>Data Criação</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    <% if (entregas && entregas.length > 0) { %>
      <% entregas.forEach(entrega => { %>
        <tr>
          <td><%= entrega.id %></td>
          <td><%= entrega.descricao %></td>
          <td><%= entrega.origem %></td>
          <td><%= entrega.destino %></td>
          <td><%= entrega.status %></td>
          <td><%= entrega.createdAt ? new Date(entrega.createdAt).toLocaleDateString('pt-BR') : '-' %></td>
          <td>
            <a href="/painel/entregas/<%= entrega.id %>">Ver</a>
          </td>
        </tr>
      <% }); %>
    <% } else { %>
      <tr>
        <td colspan="7">Nenhuma entrega encontrada</td>
      </tr>
    <% } %>
  </tbody>
</table>

<div class="paginacao">
  <% if (page > 1) { %>
    <a href="/painel/entregas?page=<%= page - 1 %><%= statusSelecionado ? '&status=' + statusSelecionado : '' %>">Anterior</a>
  <% } %>
  
  <span>Página <%= page %> de <%= totalPages %></span>
  
  <% if (page < totalPages) { %>
    <a href="/painel/entregas?page=<%= page + 1 %><%= statusSelecionado ? '&status=' + statusSelecionado : '' %>">Próxima</a>
  <% } %>
</div>

<div>
  <a href="/painel">
    <button type="button">Voltar</button>
  </a>
</div>
